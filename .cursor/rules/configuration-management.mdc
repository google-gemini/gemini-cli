## Configuration File Management

### Multiple Format Support
```typescript
// ✅ GOOD: Support multiple configuration formats
export async function loadConfigFromFile(
  configPath?: string
): Promise<Partial<AppConfig> | null> {
  const paths = [
    configPath,
    './config.json',
    './config.js',
    './config.ts',
    './.env',
    './.env.local'
  ].filter(Boolean) as string[];

  for (const path of paths) {
    try {
      if (path.endsWith('.json')) {
        const content = await fs.readFile(path, 'utf8');
        return JSON.parse(content);
      }

      if (path.endsWith('.js') || path.endsWith('.ts')) {
        const configModule = await import(path);
        return configModule.default || configModule;
      }

      if (path.startsWith('.env')) {
        return loadFromEnvFile(path);
      }
    } catch (error) {
      // Continue to next path
      console.debug(`Failed to load config from ${path}:`, error);
    }
  }

  return null;
}
```

### Configuration Hot Reloading
```typescript
// ✅ GOOD: Configuration hot reloading
export class ConfigurationManager {
  private config: AppConfig;
  private watcher?: fs.FSWatcher;
  private onChange?: (config: AppConfig) => void;

  constructor(initialConfig: AppConfig) {
    this.config = initialConfig;
  }

  async watchConfigFile(configPath: string): Promise<void> {
    this.watcher = fs.watch(configPath, { persistent: false });

    for await (const event of this.watcher) {
      if (event.eventType === 'change') {
        try {
          const newConfig = await loadConfigFromFile(configPath);
          if (newConfig) {
            this.config = { ...this.config, ...newConfig };
            this.onChange?.(this.config);
          }
        } catch (error) {
          console.error('Failed to reload configuration:', error);
        }
      }
    }
  }

  onConfigChange(callback: (config: AppConfig) => void): void {
    this.onChange = callback;
  }

  getConfig(): AppConfig {
    return { ...this.config };
  }

  async close(): Promise<void> {
    await this.watcher?.close();
  }
}
```

## Command Line Argument Handling

### Structured CLI Configuration
```typescript
// ✅ GOOD: Type-safe command line argument parsing
import { Command } from 'commander';

export interface CLIConfig {
  port?: number;
  host?: string;
  config?: string;
  verbose?: boolean;
}

export function parseCLIArgs(): CLIConfig {
  const program = new Command();

  program
    .name('myapp')
    .description('My application')
    .version('1.0.0');

  program
    .option('-p, --port <number>', 'server port', parseInt)
    .option('-h, --host <string>', 'server host')
    .option('-c, --config <path>', 'configuration file path')
    .option('-v, --verbose', 'enable verbose logging');

  program.parse();

  return program.opts<CLIConfig>();
}
```

### Configuration Precedence Documentation
```typescript
// ✅ GOOD: Document configuration precedence clearly
/**
 * Configuration Loading Order (highest precedence first):
 *
 * 1. Command Line Arguments (--port, --host, etc.)
 * 2. Environment Variables (PORT, HOST, etc.)
 * 3. Configuration File (config.json, .env, etc.)
 * 4. Environment-Specific Defaults (production, staging, development)
 * 5. Global Defaults
 *
 * Each level can override values from lower levels.
 * Use this order to provide flexibility for different deployment scenarios.
 */
