## Secret Management

### Secure Secret Handling
```typescript
// ✅ GOOD: Secure secret management
export class SecretManager {
  private secrets: Map<string, string> = new Map();

  async loadSecrets(): Promise<void> {
    // Load from secure sources (not plain environment variables)
    const secretFiles = [
      '/run/secrets/db_password',
      '/etc/myapp/secrets.json'
    ];

    for (const file of secretFiles) {
      try {
        if (file.endsWith('.json')) {
          const content = await fs.readFile(file, 'utf8');
          const secrets = JSON.parse(content);
          Object.entries(secrets).forEach(([key, value]) => {
            this.secrets.set(key, value as string);
          });
        } else {
          const value = await fs.readFile(file, 'utf8');
          const key = path.basename(file);
          this.secrets.set(key, value.trim());
        }
      } catch (error) {
        // Log but don't fail - secrets might be optional
        console.warn(`Failed to load secret from ${file}:`, error);
      }
    }
  }

  getSecret(key: string): string | undefined {
    return this.secrets.get(key);
  }

  getRequiredSecret(key: string): string {
    const secret = this.secrets.get(key);
    if (!secret) {
      throw new ConfigurationError(`Required secret '${key}' not found`);
    }
    return secret;
  }
}
```

### Secret Validation
```typescript
// ✅ GOOD: Secret validation without logging values
export function validateSecrets(secrets: Record<string, string>): void {
  const requiredSecrets = ['JWT_SECRET', 'DB_PASSWORD', 'ENCRYPTION_KEY'];

  const missingSecrets = requiredSecrets.filter(key => !secrets[key]);

  if (missingSecrets.length > 0) {
    throw new ConfigurationError(
      `Missing required secrets: ${missingSecrets.join(', ')}`
    );
  }

  // Validate secret strength without exposing values
  if (secrets.JWT_SECRET && secrets.JWT_SECRET.length < 32) {
    throw new ConfigurationError('JWT_SECRET must be at least 32 characters long');
  }

  if (secrets.ENCRYPTION_KEY && secrets.ENCRYPTION_KEY.length < 16) {
    throw new ConfigurationError('ENCRYPTION_KEY must be at least 16 characters long');
  }
}
```

## Configuration Testing

### Configuration Testing Patterns
```typescript
// ✅ GOOD: Comprehensive configuration testing
describe('Configuration Management', () => {
  describe('loadConfiguration', () => {
    it('should load default configuration', () => {
      const config = loadConfiguration();
      expect(config.api.port).toBe(3000);
      expect(config.database.host).toBe('localhost');
    });

    it('should override defaults with environment variables', () => {
      vi.stubEnv('API_PORT', '8080');
      vi.stubEnv('DB_HOST', 'prod-db.example.com');

      const config = loadConfiguration();

      expect(config.api.port).toBe(8080);
      expect(config.database.host).toBe('prod-db.example.com');
    });

    it('should validate configuration and throw on invalid values', () => {
      vi.stubEnv('API_PORT', 'invalid');

      expect(() => loadConfiguration()).toThrow(ConfigurationError);
    });

    it('should support different environments', () => {
      vi.stubEnv('NODE_ENV', 'production');

      const config = loadConfiguration();

      expect(config.logging.level).toBe('warn');
      expect(config.database.name).toBe('prod_db');
    });
  });

  describe('Secret Management', () => {
    it('should load secrets from secure files', async () => {
      const secretManager = new SecretManager();
      await secretManager.loadSecrets();

      expect(secretManager.getSecret('db_password')).toBeDefined();
      expect(secretManager.getSecret('jwt_secret')).toBeDefined();
    });

    it('should throw on missing required secrets', () => {
      const secretManager = new SecretManager();

      expect(() => secretManager.getRequiredSecret('missing_secret'))
        .toThrow('Required secret \'missing_secret\' not found');
    });

    it('should validate secret strength', () => {
      const weakSecrets = { JWT_SECRET: 'weak' };

      expect(() => validateSecrets(weakSecrets))
        .toThrow('JWT_SECRET must be at least 32 characters long');
    });
  });
});
```

