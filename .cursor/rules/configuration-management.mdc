# Configuration Management Best Practices

## Core Principles

### 1. Use Hierarchical Configuration Sources
**Why**: Provides flexibility and allows different environments to override defaults.

**Pattern**:
```typescript
// ✅ GOOD: Hierarchical configuration loading
export interface AppConfig {
  database: {
    host: string;
    port: number;
    name: string;
  };
  api: {
    port: number;
    timeout: number;
  };
  logging: {
    level: 'debug' | 'info' | 'warn' | 'error';
    file?: string;
  };
}

export function loadConfiguration(): AppConfig {
  // 1. Start with defaults
  const config: AppConfig = getDefaultConfig();

  // 2. Override with config file
  const fileConfig = loadConfigFromFile();
  if (fileConfig) {
    deepMerge(config, fileConfig);
  }

  // 3. Override with environment variables
  const envConfig = loadConfigFromEnvironment();
  deepMerge(config, envConfig);

  // 4. Override with command line arguments
  const cliConfig = loadConfigFromCLI();
  deepMerge(config, cliConfig);

  return config;
}
```

### 2. Validate Configuration Early
**Why**: Catches configuration errors immediately rather than during runtime.

**Pattern**:
```typescript
// ✅ GOOD: Configuration validation with detailed errors
import { z } from 'zod';

const configSchema = z.object({
  database: z.object({
    host: z.string().min(1, 'Database host is required'),
    port: z.number().int().min(1).max(65535),
    name: z.string().min(1, 'Database name is required'),
    password: z.string().min(8, 'Database password must be at least 8 characters')
  }),
  api: z.object({
    port: z.number().int().min(1).max(65535),
    timeout: z.number().int().min(1000).max(30000)
  }),
  logging: z.object({
    level: z.enum(['debug', 'info', 'warn', 'error']),
    file: z.string().optional()
  })
});

export function validateConfiguration(config: unknown): AppConfig {
  try {
    return configSchema.parse(config);
  } catch (error) {
    if (error instanceof z.ZodError) {
      const issues = error.issues.map(issue =>
        `${issue.path.join('.')}: ${issue.message}`
      ).join('\n');

      throw new ConfigurationError(
        `Configuration validation failed:\n${issues}`
      );
    }
    throw error;
  }
}
```

### 3. Use Environment-Specific Configurations
**Why**: Different environments (development, staging, production) have different requirements.

**Pattern**:
```typescript
// ✅ GOOD: Environment-aware configuration
export function getEnvironmentConfig(): Partial<AppConfig> {
  const nodeEnv = process.env.NODE_ENV || 'development';

  switch (nodeEnv) {
    case 'production':
      return {
        database: {
          host: process.env.DB_HOST || 'localhost',
          port: parseInt(process.env.DB_PORT || '5432'),
          name: process.env.DB_NAME || 'prod_db'
        },
        logging: {
          level: 'warn',
          file: '/var/log/app/app.log'
        }
      };

    case 'staging':
      return {
        database: {
          host: process.env.DB_HOST || 'staging-db.example.com',
          port: parseInt(process.env.DB_PORT || '5432'),
          name: process.env.DB_NAME || 'staging_db'
        },
        logging: {
          level: 'info',
          file: '/var/log/app/staging.log'
        }
      };

    default: // development
      return {
        database: {
          host: process.env.DB_HOST || 'localhost',
          port: parseInt(process.env.DB_PORT || '5432'),
          name: process.env.DB_NAME || 'dev_db'
        },
        logging: {
          level: 'debug'
        }
      };
  }
}
```

## Environment Variable Handling

### Type-Safe Environment Variables
```typescript
// ✅ GOOD: Type-safe environment variable parsing
function parseEnvVar<T>(
  name: string,
  parser: (value: string) => T,
  defaultValue?: T
): T {
  const value = process.env[name];

  if (value === undefined) {
    if (defaultValue !== undefined) {
      return defaultValue;
    }
    throw new ConfigurationError(`Environment variable ${name} is required`);
  }

  try {
    return parser(value);
  } catch (error) {
    throw new ConfigurationError(
      `Invalid value for ${name}: ${value}. ${error.message}`
    );
  }
}

// Usage
const config = {
  port: parseEnvVar('PORT', parseInt, 3000),
  host: parseEnvVar('HOST', String, 'localhost'),
  debug: parseEnvVar('DEBUG', value => value === 'true', false),
  timeout: parseEnvVar('TIMEOUT', parseInt, 5000)
};
```

