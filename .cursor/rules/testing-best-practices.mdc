### Edge Case and Error Testing
```typescript
// ✅ GOOD: Comprehensive edge case coverage
describe('Data Validation', () => {
  describe('Email Validation', () => {
    const validEmails = [
      'user@example.com',
      'user.name+tag@example.co.uk',
      'user@localhost'
    ];

    const invalidEmails = [
      '',
      'invalid',
      '@example.com',
      'user@',
      'user@@example.com'
    ];

    it.each(validEmails)('should accept valid email: %s', (email) => {
      expect(validateEmail(email)).toBe(true);
    });

    it.each(invalidEmails)('should reject invalid email: %s', (email) => {
      expect(validateEmail(email)).toBe(false);
    });
  });

  describe('Error Conditions', () => {
    it('should handle null input gracefully', () => {
      expect(() => validateEmail(null)).not.toThrow();
      expect(validateEmail(null)).toBe(false);
    });

    it('should handle undefined input gracefully', () => {
      expect(() => validateEmail(undefined)).not.toThrow();
      expect(validateEmail(undefined)).toBe(false);
    });

    it('should handle extremely long input', () => {
      const longEmail = 'a'.repeat(1000) + '@example.com';
      expect(validateEmail(longEmail)).toBe(false);
    });
  });
});
```

## Async Testing Patterns

### Promise and Async/Await Testing
```typescript
// ✅ GOOD: Proper async testing
it('should resolve with correct data', async () => {
  const result = await fetchUserData(userId);
  expect(result).toHaveProperty('id', userId);
  expect(result).toHaveProperty('name');
});

it('should reject with appropriate error', async () => {
  await expect(fetchUserData(invalidId)).rejects.toThrow('User not found');
});

// ✅ GOOD: Testing timeouts
it('should complete within timeout', async () => {
  const startTime = Date.now();
  await performLongOperation();
  const duration = Date.now() - startTime;
  expect(duration).toBeLessThan(5000); // 5 seconds
});
```

### Timer and Scheduling Testing
```typescript
// ✅ GOOD: Testing setTimeout/setInterval
it('should execute callback after delay', async () => {
  vi.useFakeTimers();
  const callback = vi.fn();

  startDelayedOperation(callback);

  expect(callback).not.toHaveBeenCalled();

  vi.advanceTimersByTime(1000);

  expect(callback).toHaveBeenCalledTimes(1);

  vi.useRealTimers();
});
```

## Integration and E2E Testing

### API Integration Testing
```typescript
// ✅ GOOD: API integration test structure
describe('User API Integration', () => {
  let server: Server;
  let baseUrl: string;

  beforeAll(async () => {
    server = await startTestServer();
    baseUrl = server.url;
  });

  afterAll(async () => {
    await server.close();
  });

  beforeEach(() => {
    // Reset database or mock data
  });

  it('should create and retrieve user', async () => {
    // Create user
    const createResponse = await fetch(`${baseUrl}/users`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: 'John Doe', email: 'john@example.com' })
    });

    expect(createResponse.status).toBe(201);
    const createdUser = await createResponse.json();

    // Retrieve user
    const getResponse = await fetch(`${baseUrl}/users/${createdUser.id}`);
    expect(getResponse.status).toBe(200);
    const retrievedUser = await getResponse.json();

    expect(retrievedUser.name).toBe('John Doe');
    expect(retrievedUser.email).toBe('john@example.com');
  });
});
```

## Test Utilities and Helpers

### Custom Test Matchers
```typescript
// ✅ GOOD: Custom matchers for common assertions
expect.extend({
  toBeValidUUID(received) {
    const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;
    const pass = uuidRegex.test(received);

    return {
      message: () => `expected ${received} to be a valid UUID`,
      pass
    };
  },

  toBeValidEmail(received) {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const pass = emailRegex.test(received);

    return {
      message: () => `expected ${received} to be a valid email`,
      pass
    };
  }
});

// Usage
expect(user.id).toBeValidUUID();
expect(user.email).toBeValidEmail();
```

