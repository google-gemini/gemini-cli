# Testing Best Practices and Patterns

## Core Principles

### 1. Test Behavior, Not Implementation
**Why**: Tests should be resilient to refactoring and focus on what the code does, not how it does it.

**Pattern**:
```typescript
// ✅ GOOD: Test behavior and outcomes
describe('UserAuthentication', () => {
  it('should allow valid login credentials', async () => {
    const result = await authenticateUser('valid@example.com', 'password123');
    expect(result.success).toBe(true);
    expect(result.user).toHaveProperty('id');
    expect(result.token).toBeDefined();
  });

  it('should reject invalid credentials', async () => {
    const result = await authenticateUser('invalid@example.com', 'wrong');
    expect(result.success).toBe(false);
    expect(result.error).toContain('Invalid credentials');
  });
});

// ❌ AVOID: Testing implementation details
it('should call database with correct SQL query', () => {
  const spy = vi.spyOn(database, 'query');
  authenticateUser('user@example.com', 'password');
  expect(spy).toHaveBeenCalledWith('SELECT * FROM users WHERE email = ?');
});
```

### 2. Use Descriptive Test Names
**Why**: Test names should clearly communicate what behavior is being tested.

**Pattern**:
```typescript
// ✅ GOOD: Clear, descriptive test names
describe('Password Reset Flow', () => {
  it('should send reset email to valid user email', async () => {
    // Test implementation
  });

  it('should not send reset email to non-existent user', async () => {
    // Test implementation
  });

  it('should expire reset token after 24 hours', async () => {
    // Test implementation
  });

  it('should prevent reuse of reset token after successful reset', async () => {
    // Test implementation
  });
});

// ❌ AVOID: Vague or implementation-focused names
it('should work', () => {});
it('should call sendEmail', () => {});
it('should return true', () => {});
```

### 3. Structure Tests with AAA Pattern
**Why**: Clear test structure improves readability and maintainability.

**Pattern**:
```typescript
// ✅ GOOD: Arrange-Act-Assert pattern
it('should calculate total price with tax', () => {
  // Arrange: Set up test data and mocks
  const items = [
    { price: 10, quantity: 2 },
    { price: 5, quantity: 1 }
  ];
  const taxRate = 0.08;
  const calculator = new PriceCalculator(taxRate);

  // Act: Execute the code under test
  const result = calculator.calculateTotal(items);

  // Assert: Verify the expected outcome
  expect(result.subtotal).toBe(25);
  expect(result.tax).toBe(2);
  expect(result.total).toBe(27);
});
```

## Mocking and Test Isolation

### Comprehensive Mocking Strategy
```typescript
// ✅ GOOD: Proper mocking setup
describe('API Client', () => {
  let mockFetch: vi.MockedFunction<typeof fetch>;

  beforeEach(() => {
    mockFetch = vi.fn();
    vi.stubGlobal('fetch', mockFetch);
  });

  afterEach(() => {
    vi.restoreAllMocks();
  });

  it('should handle successful API responses', async () => {
    // Arrange
    mockFetch.mockResolvedValueOnce({
      ok: true,
      json: () => Promise.resolve({ data: 'test' })
    });

    // Act
    const result = await apiClient.getData();

    // Assert
    expect(result).toEqual({ data: 'test' });
    expect(mockFetch).toHaveBeenCalledWith('/api/data');
  });

  it('should retry on network failures', async () => {
    // Arrange
    mockFetch
      .mockRejectedValueOnce(new Error('Network error'))
      .mockResolvedValueOnce({
        ok: true,
        json: () => Promise.resolve({ data: 'retry success' })
      });

    // Act
    const result = await apiClient.getData();

    // Assert
    expect(result).toEqual({ data: 'retry success' });
    expect(mockFetch).toHaveBeenCalledTimes(2);
  });
});
```

