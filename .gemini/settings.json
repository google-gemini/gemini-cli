{
  "experimental": {
    "plan": true,
    "extensionReloading": true,
    "modelSteering": true,
    "memoryManager": true
  },
  "general": {
    "devtools": true
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "npx block-no-verify@1.1.2",
            "description": "Block git hook-bypass flag to protect pre-commit, commit-msg, and pre-push hooks"
          }
        ]
      }
    ]
  }
}