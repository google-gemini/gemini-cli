{
  "version": "0.2.0",

  "configurations": [
    {
      "name": "CLI: Build & Start",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build-and-start"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "GEMINI_SANDBOX": "false",
        "NODE_ENV": "development"
      }
    },

    {
      "name": "CLI: Run Current File",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**"],
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "env": {
        "NODE_ENV": "development"
      }
    },

    {
      "name": "CLI: Attach (9229)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"],
      "restart": true,
      "timeout": 10000,
      "localRoot": "${workspaceFolder}/packages",
      "remoteRoot": "/usr/local/share/npm-global/lib/node_modules/@gemini-cli"
    },

    {
      "name": "VSCode Extension: Debug",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-ide-companion"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-ide-companion/dist/**/*.js"
      ],
      "preLaunchTask": "npm: build: vscode-ide-companion"
    },

    {
      "name": "Test: Unit (Single File)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "test",
        "-w",
        "packages",
        "--",
        "--inspect-brk=9229",
        "--no-file-parallelism",
        "${input:testFile}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "test"
      }
    },

    {
      "name": "Test: Integration",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "vitest",
        "run",
        "--root",
        "./integration-tests",
        "--inspect-brk=9229",
        "${file}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "GEMINI_SANDBOX": "false",
        "NODE_ENV": "test"
      }
    }
  ],

  "inputs": [
    {
      "id": "testFile",
      "type": "promptString",
      "description": "Enter test file path",
      "default": "${workspaceFolder}/packages/cli/src/ui/components/LoadingIndicator.test.tsx"
    }
  ]
}
