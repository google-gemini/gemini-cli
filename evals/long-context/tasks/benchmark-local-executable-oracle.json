        "label": "fail-to-pass local artifact check",
        "command": "python3",
        "args": [
          "-c",
          "from pathlib import Path; print(Path('artifacts/result.txt').read_text())"
        ],
        "expectedExitCode": 0,
        "stdoutIncludes": ["LOCAL_BENCHMARK_SUCCESS"],
        "stderrIncludes": []
      }
