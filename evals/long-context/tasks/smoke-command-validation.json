    "outputFormat": "stream-json",
    "approvalMode": "yolo",
    "cliArgs": []
  },
  "validation": {
    "type": "command",
    "command": "python3",
    "args": [
      "-c",
      "from pathlib import Path; print(Path('output.txt').read_text())"
    ],
    "expectedExitCode": 0,
    "stdoutIncludes": ["COMMAND_SMOKE_SUCCESS"],
    "stderrIncludes": []
  },
  "tags": ["smoke", "command-validation"]
