    "gen_ai.output.messages": "[{\"finish_reason\":\"stop\",\"role\":\"system\",\"parts\":[{\"type\":\"text\",\"content\":\"I will ask for your favorite color using the `ask_user` tool.\"}]},{\"finish_reason\":\"stop\",\"role\":\"system\",\"parts\":[{\"type\":\"tool_call\",\"name\":\"ask_user\",\"arguments\":\"{\\\"questions\\\":[{\\\"question\\\":\\\"What is your favorite color?\\\",\\\"type\\\":\\\"choice\\\",\\\"header\\\":\\\"Fav Color\\\",\\\"options\\\":[{\\\"description\\\":\\\"The color of fire and passion.\\\",\\\"label\\\":\\\"red\\\"},{\\\"description\\\":\\\"The color of nature and growth.\\\",\\\"label\\\":\\\"green\\\"},{\\\"description\\\":\\\"The color of the sky and ocean.\\\",\\\"label\\\":\\\"blue\\\"}]}]}\"}]},{\"finish_reason\":\"stop\",\"role\":\"system\",\"parts\":[{\"type\":\"unknown\",\"text\":\"\"}]}]",
    "gen_ai.request.temperature": 1,
