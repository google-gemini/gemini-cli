// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ReadFileTool > getSchema > should return the Gemini 3 schema when a Gemini 3 modelId is provided 1`] = `"Reads and returns the content of a specified file. To maintain context efficiency, you MUST use 'start_line' and 'end_line' for targeted, surgical reads of specific sections. The tool will reject reads of text files exceeding 512 KiB unless start_line/end_line is specified, and will reject any file over 20MB. Always retrieve only the minimum content necessary for your next step. Handles text, images (PNG, JPG, GIF, WEBP, SVG, BMP), audio files (MP3, WAV, AIFF, AAC, OGG, FLAC), and PDF files."`;

exports[`ReadFileTool > getSchema > should return the base schema when no modelId is provided 1`] = `"Reads and returns the content of a specified file. Handles text, images (PNG, JPG, GIF, WEBP, SVG, BMP), audio files (MP3, WAV, AIFF, AAC, OGG, FLAC), and PDF files. For text files, it can read specific line ranges using 'start_line' and 'end_line' parameters. If a text file exceeds 512 KiB without start_line/end_line specified, the read will be rejected with guidance to read specific sections."`;

exports[`ReadFileTool > getSchema > should return the schema from the resolver when modelId is provided 1`] = `"Reads and returns the content of a specified file. Handles text, images (PNG, JPG, GIF, WEBP, SVG, BMP), audio files (MP3, WAV, AIFF, AAC, OGG, FLAC), and PDF files. For text files, it can read specific line ranges using 'start_line' and 'end_line' parameters. If a text file exceeds 512 KiB without start_line/end_line specified, the read will be rejected with guidance to read specific sections."`;
