{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/src",
    "composite": true,
    "declaration": true,
    "sourceMap": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "incremental": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src"]
}
