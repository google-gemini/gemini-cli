#!/usr/bin/env python3
"""
pcc-critic - PCC 制約注入で Gemini CLI / Jules / Claude の critic 品質を底上げする。

Usage:
    pcc-critic "semantic_delta の弱点を指摘しろ"
    pcc-critic --preset 極 "このコードをレビューしろ"
    pcc-critic --model gemini-3.1-pro-preview --preset 探 "設計の穴を見つけろ"
    cat code.py | pcc-critic --preset 監 "この差分を監査しろ"
    cat notes.txt | pcc-critic --audit-only --json

User config: ~/.pcc-critic.json
Override with: --config path/to/pcc-critic.json or PCC_CRITIC_CONFIG_PATH

Supported keys:
    {
        "model_routing": {
            "deep": "gemini-3.1-pro-preview"
        },
        "runtime_commands": {
            "jules": ["jules", "run", "--prompt", "{prompt}"]
        }
    }
"""

import argparse
import json
import os
import pathlib
import shutil
import subprocess
import sys
import time
from typing import Any


PCC_PRESETS: dict[str, dict[str, Any]] = {
    "探": {
        "label": "#探 (Critical Explorer)",
        "constraints": [
            "Explore multiple perspectives and challenge all assumptions",
            "Identify specific weaknesses with concrete reasoning",
            "Do NOT be agreeable - be a constructive critic",
            "Support each point with examples or scenarios",
            "If there are no weaknesses, say so explicitly - do not fabricate",
        ],
    },
    "極": {
        "label": "#極 (Maximum Precision)",
        "constraints": [
            "Be extremely concise - no filler, no pleasantries",
            "Answer only what is asked, nothing more",
            "Use structured output (numbered lists, tables)",
            "If you cannot answer precisely, state why",
        ],
    },
    "均": {
        "label": "#均 (Balanced Review)",
        "constraints": [
            "Provide equal weight to strengths and weaknesses",
            "For each weakness, suggest a concrete improvement",
            "Be honest but constructive",
            "Prioritize actionable feedback over theoretical concerns",
        ],
    },
    "監": {
        "label": "#監 (Audit Mode)",
        "constraints": [
            "Evaluate based on evidence only: diff, tests, logs, exit codes",
            "Ignore natural language self-reports of success",
            "Classify result as: PASS / NEEDS_EVIDENCE / NO_OP / FAIL",
            "If no evidence is provided, verdict is NEEDS_EVIDENCE",
            "State exactly what evidence is missing",
        ],
    },
    "刃": {
        "label": "#刃 (Blade - Implementation Reviewer)",
        "constraints": [
            "You are a strict implementation designer and code reviewer",
            "First examine related files and existing implementation - judge based on facts only",
            "Never assert unverified claims. Mark guesses explicitly as 'Assumption'",
            "Do NOT stop at one option - compare at least 3 alternatives",
            "For each alternative, output: changes / blast radius / risks / test focus / likely failure points",
            "Recommend the safest option with clear justification",
            "Before saying 'done', present the actual evidence you verified",
            "If information is missing, state a reasonable assumption and proceed",
            "No verbose preamble. Output at maximum density",
        ],
        "output_format": """Output format (MANDATORY):
    1. 結論 / Conclusion
    2. 現状理解 / Current Understanding
    3. 代替案 A / B / C / Alternatives
    4. 推奨案 / Recommendation
    5. 実装手順 / Implementation Steps
    6. テスト観点 / Test Perspectives
    7. 残る不確実性 / Remaining Uncertainties""",
    },
}


MODEL_ROUTING = {
    "fast": "gemini-2.5-flash",
    "standard": "gemini-2.5-pro",
    "deep": "gemini-3.1-pro-preview",
    "claude-sonnet": "claude-sonnet-4-6",
    "claude-opus": "claude-opus-4-6",
}


DEFAULT_CONFIG_PATH = pathlib.Path.home() / ".pcc-critic.json"


def resolve_config_path(config_arg: str | None) -> pathlib.Path:
    configured = config_arg or os.environ.get("PCC_CRITIC_CONFIG_PATH")
    if configured:
        path = pathlib.Path(configured).expanduser()
        if not path.is_absolute():
            path = pathlib.Path.cwd() / path
        return path
    return DEFAULT_CONFIG_PATH


def load_user_config(config_path: pathlib.Path) -> dict[str, Any]:
    if not config_path.exists():
        return {}

    try:
        return json.loads(config_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError) as exc:
        print(
            f"[PCC] Warning: failed to load {config_path}: {exc}",
            file=sys.stderr,
        )
        return {}


def load_model_routing(config_path: pathlib.Path) -> dict[str, str]:
    merged = dict(MODEL_ROUTING)
    config = load_user_config(config_path)
    user_routing = config.get("model_routing")
    if isinstance(user_routing, dict):
        for key, value in user_routing.items():
            if isinstance(key, str) and isinstance(value, str):
                merged[key] = value
    return merged


def load_runtime_commands(config_path: pathlib.Path) -> dict[str, list[str]]:
    config = load_user_config(config_path)
    runtime_commands = config.get("runtime_commands")
    if not isinstance(runtime_commands, dict):
        return {}

    normalized: dict[str, list[str]] = {}
    for name, command in runtime_commands.items():
        if not isinstance(name, str) or not isinstance(command, list):
            continue
        if all(isinstance(part, str) for part in command):
            normalized[name] = list(command)
    return normalized


def inject_pcc(prompt: str, preset: str) -> str:
    config = PCC_PRESETS.get(preset)
    if not config:
        print(f"[PCC] Unknown preset: {preset}, falling back to #探", file=sys.stderr)
        config = PCC_PRESETS["探"]

    constraints = "\n".join(f"  - {constraint}" for constraint in config["constraints"])
    output_format = config.get("output_format", "")
    output_block = f"\n\n{output_format}" if output_format else ""

    return f"""[PCC Protocol: {config['label']}]
Constraints:
{constraints}
{output_block}
---
{prompt}"""


def resolve_node_path() -> str | None:
    nvm_dir = os.path.expanduser("~/.nvm")
    command = (
        f'bash -c "source {nvm_dir}/nvm.sh >/dev/null 2>&1 && '
        'nvm which node 2>/dev/null"'
    )
    return os.popen(command).read().strip() or None


def substitute_command_parts(parts: list[str], prompt: str, model: str) -> list[str]:
    return [part.format(prompt=prompt, model=model) for part in parts]


def run_process(command: list[str], timeout: int, env: dict[str, str], cwd: str) -> dict[str, Any]:
    started = time.monotonic()
    try:
        result = subprocess.run(
            command,
            capture_output=True,
            text=True,
            env=env,
            timeout=timeout,
            cwd=cwd,
        )
        elapsed = round(time.monotonic() - started, 1)
        return {
            "text": result.stdout.strip() or result.stderr.strip(),
            "stdout": result.stdout.strip(),
            "stderr": result.stderr.strip(),
            "exit_code": result.returncode,
            "elapsed": elapsed,
            "command": command,
        }
    except subprocess.TimeoutExpired:
        return {
            "text": "",
            "stdout": "",
            "stderr": "",
            "exit_code": -1,
            "elapsed": timeout,
            "command": command,
            "error": "TIMEOUT",
        }
    except FileNotFoundError:
        return {
            "text": f"Error: command not found: {command[0]}",
            "stdout": "",
            "stderr": "",
            "exit_code": -1,
            "elapsed": 0,
            "command": command,
            "error": "NOT_FOUND",
        }


def run_gemini(enriched_prompt: str, model: str, timeout: int = 120) -> dict[str, Any]:
    env = os.environ.copy()
    node_path = resolve_node_path()
    if node_path:
        env["PATH"] = f"{os.path.dirname(node_path)}:{env.get('PATH', '')}"

    gemini_bin = os.environ.get("PCC_GEMINI_BIN") or shutil.which("gemini") or "/opt/homebrew/bin/gemini"
    command = [gemini_bin, "-p", enriched_prompt, "-m", model]
    result = run_process(command, timeout, env, os.path.expanduser("~"))
    result["model"] = model
    return result


def run_claude(enriched_prompt: str, model: str, timeout: int = 120) -> dict[str, Any]:
    env = os.environ.copy()
    claude_bin = os.environ.get("PCC_CLAUDE_BIN") or shutil.which("claude") or "claude"
    command = [claude_bin, "-p", "--model", model, enriched_prompt]
    result = run_process(command, timeout, env, os.path.expanduser("~"))
    result["model"] = model
    return result


def run_configured_runtime(
    runtime: str,
    enriched_prompt: str,
    model: str,
    config_path: pathlib.Path,
    timeout: int = 120,
) -> dict[str, Any]:
    runtime_commands = load_runtime_commands(config_path)
    command_template = runtime_commands.get(runtime)
    if not command_template:
        return {
            "text": (
                f"Error: runtime '{runtime}' is not configured. "
                f"Add runtime_commands.{runtime} to {config_path}."
            ),
            "stdout": "",
            "stderr": "",
            "exit_code": -1,
            "elapsed": 0,
            "model": model,
            "error": "RUNTIME_NOT_CONFIGURED",
        }

    env = os.environ.copy()
    command = substitute_command_parts(command_template, enriched_prompt, model)
    result = run_process(command, timeout, env, os.path.expanduser("~"))
    result["model"] = model
    return result


def audit_response(text: str) -> dict[str, Any]:
    if not text or len(text.strip()) < 20:
        return {
            "verdict": "NO_OP",
            "sycophancy": 0.0,
            "evidence_count": 0,
            "words": 0,
        }

    lower = text.lower()
    words = len(text.split())

    sycophancy_markers = [
        "great question",
        "excellent point",
        "absolutely right",
        "wonderful",
        "that's a great idea",
        "you're absolutely",
        "brilliant",
        "i love this",
    ]
    sycophancy = sum(1 for marker in sycophancy_markers if marker in lower) / 3.0

    evidence_markers = [
        "however",
        "risk",
        "weakness",
        "problem",
        "flaw",
        "limitation",
        "because",
        "specifically",
        "example",
        "breaking",
        "failure",
        "impossible",
        "incorrect",
        "矛盾",
        "欠陥",
        "弱点",
        "問題",
        "不可能",
        "破綻",
        "危険",
    ]
    evidence = sum(1 for marker in evidence_markers if marker in lower)

    if sycophancy > 0.5:
        verdict = "SYCOPHANTIC"
    elif evidence >= 3:
        verdict = "PASS"
    elif evidence >= 1:
        verdict = "REVIEW"
    elif words < 50:
        verdict = "NO_OP"
    else:
        verdict = "NEEDS_EVIDENCE"

    return {
        "verdict": verdict,
        "sycophancy": round(min(sycophancy, 1.0), 2),
        "evidence_count": evidence,
        "words": words,
    }


def main() -> None:
    if hasattr(sys.stdout, "reconfigure"):
        sys.stdout.reconfigure(encoding="utf-8")
    if hasattr(sys.stderr, "reconfigure"):
        sys.stderr.reconfigure(encoding="utf-8")

    parser = argparse.ArgumentParser(
                description="PCC Critic - PCC 制約注入で Gemini CLI / Jules / Claude を厳格に制御する",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Presets:
    探  批判的探索 (default)
    極  極限精度
    均  バランス型
    監  監査特化
    刃  実装設計レビュー

Config:
  default  ~/.pcc-critic.json
  override --config path/to/pcc-critic.json
  env      PCC_CRITIC_CONFIG_PATH=path/to/pcc-critic.json

Runtimes:
  gemini   Gemini CLI adapter
  claude   Claude CLI adapter
  jules    configured via runtime_commands.jules in the selected config
""",
    )
    parser.add_argument("prompt", nargs="?", help="プロンプト (stdin からも読める)")
    parser.add_argument("--preset", "-P", default="探", choices=PCC_PRESETS.keys())
    parser.add_argument("--model", "-m", default="deep")
    parser.add_argument("--config", help="PCC config path を上書き")
    parser.add_argument("--timeout", "-t", type=int, default=120)
    parser.add_argument("--json", "-j", action="store_true", help="JSON を出力")
    parser.add_argument("--max-input-chars", type=int, default=100000)
    parser.add_argument(
        "--runtime",
        choices=["gemini", "claude", "jules"],
        default="gemini",
                help="実行ランタイム",
    )
    parser.add_argument(
        "--audit-only",
        action="store_true",
                help="LLM を呼ばず、与えたテキストだけ監査する",
    )
    args = parser.parse_args()

    stdin_text = ""
    if not sys.stdin.isatty():
        stdin_text = sys.stdin.read().strip()
        if len(stdin_text) > args.max_input_chars:
            print(
                (
                    f"[PCC] Warning: truncating piped input from {len(stdin_text)} "
                    f"to {args.max_input_chars} characters"
                ),
                file=sys.stderr,
            )
            stdin_text = stdin_text[: args.max_input_chars]

    if args.audit_only:
        text = stdin_text or (args.prompt or "")
        audit = audit_response(text)
        if args.json:
            print(json.dumps(audit, ensure_ascii=False, indent=2))
        else:
            for key, value in audit.items():
                print(f"{key}: {value}")
        raise SystemExit(0 if audit["verdict"] == "PASS" else 1)

    prompt = args.prompt or ""
    if stdin_text:
        prompt = f"{stdin_text}\n\n---\n{prompt}" if prompt else stdin_text
    if not prompt:
        parser.error("provide a prompt or pipe input on stdin")

    config_path = resolve_config_path(args.config)
    routing = load_model_routing(config_path)
    model = routing.get(args.model, args.model)
    enriched_prompt = inject_pcc(prompt, args.preset)

    if not args.json:
        print(f"[PCC] Preset: #{args.preset} -> {PCC_PRESETS[args.preset]['label']}")
        print(f"[Runtime] {args.runtime}")
        print(f"[Model] {model}")
        print(f"[Config] {config_path}")
        print(f"[Prompt] {len(enriched_prompt)} chars")
        print("-" * 50)

    if args.runtime == "claude":
        result = run_claude(enriched_prompt, model, args.timeout)
    elif args.runtime == "gemini":
        result = run_gemini(enriched_prompt, model, args.timeout)
    else:
        result = run_configured_runtime(
            args.runtime,
            enriched_prompt,
            model,
            config_path,
            args.timeout,
        )

    audit = audit_response(result.get("text", ""))

    if args.json:
        output = {
            "pcc_preset": args.preset,
            "runtime": args.runtime,
            "model": model,
            "config_path": str(config_path),
            "response": result.get("text", ""),
            "elapsed": result.get("elapsed", 0),
            "exit_code": result.get("exit_code", -1),
            "audit": audit,
            "error": result.get("error"),
        }
        print(json.dumps(output, ensure_ascii=False, indent=2))
    else:
        print(result.get("text", ""))
        print("-" * 50)
        print(
            f"[Audit] verdict={audit['verdict']} sycophancy={audit['sycophancy']} "
            f"evidence={audit['evidence_count']} words={audit['words']} "
            f"time={result.get('elapsed', 0)}s"
        )

    raise SystemExit(0 if audit["verdict"] == "PASS" else 1)


if __name__ == "__main__":
    main()
